{
  "name": "pq-sync",
  "displayName": "pq-sync",
  "description": "Sync Power Query M code between Excel workbooks and .pq files",
  "version": "0.1.0",
  "publisher": "ricardodiaz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/camconsultores/pq-sync"
  },
  "keywords": ["power query", "excel", "M code", "xlsx", "Power BI"],
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Data Science"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "pq-sync.pull", "title": "pq-sync: Pull from Excel" },
      { "command": "pq-sync.push", "title": "pq-sync: Push to Excel" },
      { "command": "pq-sync.configure", "title": "pq-sync: Configure" },
      { "command": "pq-sync.pushQuery", "title": "pq-sync: Push this query" },
      { "command": "pq-sync.pullFromFolder", "title": "pq-sync: Pull from Excel" },
      { "command": "pq-sync.pushFromFolder", "title": "pq-sync: Push to Excel" }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "pq-sync.pushQuery",
          "when": "resourceExtname == .pq",
          "group": "pq-sync@1"
        },
        {
          "command": "pq-sync.pullFromFolder",
          "when": "explorerResourceIsFolder",
          "group": "pq-sync@1"
        },
        {
          "command": "pq-sync.pushFromFolder",
          "when": "explorerResourceIsFolder",
          "group": "pq-sync@2"
        }
      ]
    },
    "configuration": {
      "title": "pq-sync",
      "properties": {
        "pqSync.workbookPath": {
          "type": "string",
          "description": "Absolute path to the Excel workbook (.xlsx)"
        },
        "pqSync.mcodePath": {
          "type": "string",
          "description": "Absolute path to the mcode folder containing .pq files"
        },
        "pqSync.scriptsRoot": {
          "type": "string",
          "description": "Optional absolute path to an external scripts directory containing extract_mcode.ts and import_mcode.ts. When unset, the extension uses its bundled self-contained script binaries."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 && esbuild scripts/extract_mcode.ts --bundle --outfile=dist/scripts/extract_mcode.js --format=cjs --platform=node --target=node18 && esbuild scripts/import_mcode.ts --bundle --outfile=dist/scripts/import_mcode.js --format=cjs --platform=node --target=node18",
    "package": "vsce package --no-git-tag-version"
  },
  "dependencies": {
    "adm-zip": "^0.5.9",
    "@xmldom/xmldom": "^0.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  }
}
